// Styled Document Template
// Demonstrates inline styling attributes

var title = "Styled Document"
var content = "This document demonstrates styling in templates."

page {
  column(padding=20, margin=10) {
    heading title
    text content

    text(color="#333333", fontSize=14) "This text has custom color and font size."
    text(align=center) "This text is centered."
  }
}
