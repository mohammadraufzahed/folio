{
    "name": "folio/pdf",
    "description": "Modern PDF generation library for PHP 8.3+ with composable document model, layout engine, and custom template language",
    "type": "library",
    "keywords": [
        "pdf",
        "document",
        "generator",
        "layout",
        "template",
        "report"
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Folio\\Pdf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Folio\\Pdf\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "strict-pm": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
