{
    "name": "folio/pdf",
    "description": "Modern PDF generation library for PHP 8.3+ with composable document model, layout engine, and custom template language",
    "type": "library",
    "keywords": [
        "pdf",
        "document",
        "generator",
        "layout",
        "template",
        "report"
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Folio\\Pdf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Folio\\Pdf\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyse --no-progress",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "format": "php bin/format.php",
        "docs:build": "npm --prefix website run build",
        "docs:serve": "npm --prefix website run dev",
        "docs:preview": "npm --prefix website run preview"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "strict-pm": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
